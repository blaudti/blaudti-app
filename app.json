{
  "expo": {
    "name": "BlaudTI",
    "slug": "blaudti-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1a2340",
      "resizeMode": "contain"
    },
    "android": {
      "package": "br.com.blaudti.app",
      "versionCode": 3,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a2340"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#1a2340",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f8c38151-e6f6-477e-9051-76dae6703169"
      },
      "apiUrl": "https://blaudti.com.br"
    }
  }
}
